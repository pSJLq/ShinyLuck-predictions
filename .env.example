# Deployer / keeper signer (NEW dedicated wallet - never reuse casino/poker deployer keys,
# their keys sign live bots and concurrent txs cause nonce races).
PRIVATE_KEY=

# Somnia testnet RPC (default: canonical infra endpoint)
RPC_TESTNET=https://api.infra.testnet.somnia.network

# x-oracle publishing (interim: GitHub raw). Token needs repo-content write on the
# small public JSON repo only. NEVER a token with access to the main repos.
XORACLE_GH_TOKEN=
XORACLE_GH_REPO=
