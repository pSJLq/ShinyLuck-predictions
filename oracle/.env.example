# x-oracle config. Copy to oracle/.env (gitignored).

NETWORK=somniaTestnet
RPC_TESTNET=https://api.infra.testnet.somnia.network
XORACLE_POLL_S=60

# twscrape HTTP backend. "curl" (curl_cffi, browser-TLS impersonation) is the
# reliable one — the default httpx backend times out reaching x.com from many
# hosts. xoracle.py/check_account.py already default this to curl.
TWS_HTTP_BACKEND=curl

# Proxy for ALL bot accounts (unless a per-account proxy is set in
# accounts.secret.txt). Use a proxy SEPARATE from where your main X account
# browses — X links accounts by IP, so a flagged bot on your main IP endangers
# the main account. Residential/mobile survive; datacenter proxies get flagged.
# Format: http://user:pass@host:port  or  socks5://user:pass@host:port
TWS_PROXY=

# Publishing: "local" writes oracle/out/<id>.json; "github" pushes to a small
# PUBLIC repo the Somnia validators can fetch (interim host before the VPS).
# Token: fine-grained PAT scoped to ONLY this repo, permission Contents:
# Read and write. Never a token with access to other repos.
XORACLE_PUBLISH=local
XORACLE_GH_TOKEN=
XORACLE_GH_REPO=pSJLq/ShinyLuck-predictions
XORACLE_GH_BRANCH=main
# JSONs land in this subdir; resolver base url =
# https://raw.githubusercontent.com/<repo>/<branch>/x-oracle/
XORACLE_GH_DIR=x-oracle

# twscrape bot accounts are added via the CLI, not here (they land in
# oracle/accounts.db). See README.md. Cookies never leave this machine.
